{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/health",
      "destination": "https://llm-eval-pipeline-api.onrender.com/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://llm-eval-pipeline-api.onrender.com/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
